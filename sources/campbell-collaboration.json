{
  "_comment": "Machine-readable config for scripts/scrape.py. Human context in campbell-collaboration.md.",

  "discovery": "api",
  "discovery_url": "https://www.campbellcollaboration.org/wp-json/wp/v2/review",

  "url_filter": {
    "url": "https://www.campbellcollaboration.org/education/reviews/",
    "slug_prefix": "/review/"
  },

  "api": {
    "params": {"per_page": 100, "_fields": "id,slug,title,link,content"},
    "pagination": {"param": "page", "start": 1, "pages": 4},
    "json_paths": {
      "items": "",
      "title": "title/rendered",
      "url": "link",
      "description": "content/rendered"
    }
  },

  "robots_txt": "https://www.campbellcollaboration.org/robots.txt",

  "test": {
    "url": "https://www.campbellcollaboration.org/wp-json/wp/v2/review?per_page=5&page=1&_fields=id,slug,title,link,content",
    "expected_min_results": 5
  }
}
