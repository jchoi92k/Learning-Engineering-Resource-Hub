private/

# Project instructions (references private paths, logging rules, internal process)
CLAUDE.md

# Secrets — never commit. The routine reads GH_TOKEN from its cloud env vars, not from .env.
.env
.env.local
.env.*.local

# SQLite journal/WAL files (hub.db itself IS committed)
data/hub.db-journal
data/hub.db-wal
data/hub.db-shm

